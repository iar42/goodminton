# ── Required ──────────────────────────────────────────────────────────────────

# Password for the /admin panel
ADMIN_PASSWORD=changeme

# Secret used to sign session cookies (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-string

# Full public URL of your app (used in reminder links)
APP_URL=https://your-app.railway.app

# Port (Railway sets this automatically; leave as-is for local dev)
PORT=3000


# ── Email reminders (Resend — https://resend.com) ─────────────────────────────
# Sign up free: 3,000 emails/month included.
# Leave blank to disable email reminders.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address shown in reminder emails.
# Must be a domain you have verified in Resend.
EMAIL_FROM=Badminton <reminders@yourdomain.com>


# ── SMS reminders (Twilio — https://twilio.com) ───────────────────────────────
# Pay-per-SMS (~$0.01/msg). Leave blank to disable SMS reminders.

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15550000000


# ── Production ────────────────────────────────────────────────────────────────
# Uncomment when deploying to production (enables secure cookies)
# NODE_ENV=production
